---
const { project } = Astro.props;
const hasVideo = Boolean(project.introVideo);
---

<div class="floor-row">
  <div class="side-band"></div>

  <section class="floor intro-floor" id={project.slug}>
    <div class="floor-bg">
      {hasVideo ? (
        <video
          data-src={project.introVideo}
          poster={project.introImage}
          muted
          loop
          playsinline
          preload="none"
          class="intro-video"
        ></video>
      ) : (
        <img src={project.introImage} alt="" loading="lazy" />
      )}
    </div>
  </section>

  <div class="side-band"></div>
</div>

<script>
  const videos = document.querySelectorAll(".intro-video");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const video = entry.target;

        if (entry.isIntersecting) {
          if (!video.src) {
            video.src = video.dataset.src;
            video.load();
          }

          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    },
    {
      rootMargin: "800px 0px",
      threshold: 0.01
    }
  );

  videos.forEach((video) => observer.observe(video));
</script>